# Copy this file to .env and fill in your own keys.
# Get keys at: https://console.deepgram.com  |  https://www.pexels.com/api/  |  https://pixabay.com/api/docs/
DEEPGRAM_API_KEY=your_deepgram_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here

# OpenAI-compatible endpoint for script + rerank (any base URL that speaks /v1/chat/completions)
OPENAI_API_KEY=your_openai_compatible_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Output directory for generated MP4s (relative paths resolved against the project root)
OUTPUT_DIR=out

# ── Video Quality & Style ────────────────────────────────────────────────
# VIDEO_RESOLUTION: "1080p", "4k", or "8k" (Scales video, effects, and captions accordingly)
VIDEO_RESOLUTION=4k

# VIDEO_FPS: 30 or 60
VIDEO_FPS=60

# VIDEO_QUALITY: "draft" (fast encode, -preset veryfast) or "final" (slower, -preset medium -crf 18)
VIDEO_QUALITY=final

# TRANSITION_STYLE: "aggressive" (fast flash/whip cuts) or "smooth" (longer fades/dissolves)
TRANSITION_STYLE=aggressive

# CAPTION_STYLE: "minimal" (thin outline) | "bold" (thick outline, yellow emphasis) | "animated" (pop + colour)
CAPTION_STYLE=bold